{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "configMigration": true,
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "schedule:weekly",
    ":automergeMinor",
    ":disablePeerDependencies",
    ":maintainLockFilesMonthly",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "helpers:pinGitHubActionDigests"
  ],
  "pre-commit": {
    "enabled": true
  },

  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    { "matchDepTypes": ["golang", "toolchain"], "enabled": false },
    { "matchFileNames": ["docker-compose.minimal.yaml"], "enabled": false },
    {
      "description": "Disable auto-creating digest PRs",
      "matchUpdateTypes": ["digest"],
      "dependencyDashboardApproval": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true,
  "postUpdateOptions": ["gomodTidy"]
}
